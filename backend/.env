# 服务（不设置时默认 3001）
PORT=3001
NODE_ENV=development

# 数据库：本地开发先用 SQLite（无需单独启动 MySQL 服务）
DATABASE_PATH=./data/app.db
DB_PROVIDER=sqlite
# 若改回 MySQL，设为 mysql 并取消下面注释、填写账号
# DB_PROVIDER=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=outfit_tryon

# JWT（登录签发 token，必填）
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# 后续对接时再填写，不要提交到 git
# IMAGE_GEN_API_KEY=
# IMAGE_GEN_BASE_URL=
# LLM_API_KEY=
# LLM_BASE_URL=
ADMIN_SECRET=dev-admin-2026

# 虚拟试衣（不配置则返回占位图，无真实试穿效果）：
# 1）在项目下启动 tryon-service：cd tryon-service && python main.py（默认 8000 端口）
# 2）在 backend 目录配置：
TRYON_API_URL=http://localhost:8000/generate
# 人物照、衣库图会拼成完整 URL 供 tryon-service 拉取，需与前端访问后端的地址一致
BASE_URL=http://localhost:3001

# 天气（可选，不配置则用 Open-Meteo 免 key 开源 API）：
# 1）和风天气：WEATHER_PROVIDER=qweather，WEATHER_API_KEY=你的 key
# 2）自定义单 URL：WEATHER_API_URL=完整请求地址，WEATHER_API_KEY=key
# WEATHER_PROVIDER=qweather
# WEATHER_API_KEY=
# WEATHER_API_URL=
WEATHER_PROVIDER=qweather
WEATHER_API_KEY=a08a9047a4414de6a0e72fb0c2d4fb08

# 为 1 时首页 /api/recommend 才调用真实天气（否则仍是 22°C 占位）
RECOMMEND_LIVE_WEATHER=1

# 投稿审核员手机号（多个用英文逗号分隔）
REVIEWER_PHONES=17308112541
