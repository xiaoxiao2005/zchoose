# 服务（不设置时默认 3001）
PORT=3001
NODE_ENV=development

# 数据库提供者：sqlite 或 mysql（默认 sqlite）
# DB_PROVIDER=sqlite

# SQLite 配置（DB_PROVIDER=sqlite 时生效）
DATABASE_PATH=./data/app.db

# 首页 /api/recommend：默认用本地占位天气（22°C 晴）。要「真实天气」：
# RECOMMEND_LIVE_WEATHER=1
# 可选：RECOMMEND_WEATHER_SCORE=1（按标签天气重排）
# 等待真实天气的最长毫秒数（和风两步+弱网建议 ≥18000，默认 20000）
# RECOMMEND_WEATHER_BUDGET_MS=20000

# MySQL 配置（DB_PROVIDER=mysql 时生效）
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=outfit_tryon
# MYSQL_POOL_SIZE=10

# 管理接口（开通会员、衣库标签人工校正台等）：与请求头 X-Admin-Secret 或 query adminSecret 一致
# 衣库标签人工校正台 /api/admin/outfits 另需登录：Authorization: Bearer <JWT>
# ADMIN_SECRET=

# JWT（登录签发 token，必填）
JWT_SECRET=your-secret-key-change-in-production
# 登录 token 有效期，如 7d / 30d，默认 30d
JWT_EXPIRE=30d

# 后续对接时再填写，不要提交到 git
# IMAGE_GEN_API_KEY=
# IMAGE_GEN_BASE_URL=
# LLM_API_KEY=
# LLM_BASE_URL=

# 虚拟试衣（不配置则返回占位图，无真实试穿效果）：
# 1）在项目下启动 tryon-service：cd tryon-service && python main.py（默认 8000 端口）
# 2）在 backend 目录配置：
TRYON_API_URL=http://localhost:8000/generate
# 人物照、衣库图会拼成完整 URL 供 tryon-service 拉取，需与前端访问后端的地址一致
BASE_URL=http://localhost:3001

# 天气（在 RECOMMEND_LIVE_WEATHER=1 时，推荐接口会调用 getWeather）：
# - 不配下面三项：使用 Open-Meteo（免 key，需能访问外网 geocoding-api / api.open-meteo）
# - 国内稳定：和风天气 → 填 WEATHER_PROVIDER=qweather 与 WEATHER_API_KEY（在 dev.qweather.com 申请）
# - 其它厂商：WEATHER_API_URL=完整请求地址（含占位符）、WEATHER_API_KEY=key
# WEATHER_PROVIDER=qweather
# WEATHER_API_KEY=
# WEATHER_API_URL=
# 单次请求最长等待（毫秒，默认 8000），可按网络调大：WEATHER_FETCH_TIMEOUT_MS=12000

# 会员支付（Stripe）：创建 Checkout、Webhook 回调
# 测试密钥以 sk_test_ / whsec_ 开头，在 https://dashboard.stripe.com 创建产品与价格或使用 price_data（当前代码用动态 price_data）
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=
# Dashboard → Webhooks → 签名密钥；本地可用 stripe listen --forward-to localhost:3001/api/payments/webhook
STRIPE_WEBHOOK_SECRET=
# 生产环境若需调用模拟支付接口，显式设为 1（默认仅非 production 可用）
# ALLOW_PAYMENT_MOCK=1
